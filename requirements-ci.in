# CI/build dependencies — used by .github/workflows/ci.yml and publish.yml
# Regenerate: pip-compile --generate-hashes --allow-unsafe --output-file=requirements-ci.txt requirements-ci.in
# Project requires Python >=3.11; tomllib/ExceptionGroup are stdlib on supported versions.
build
# Windows-only transitive dep of build (os_name == "nt") and pytest
# (sys_platform == "win32"). pip-compile evaluates markers for the platform it
# runs on (POSIX), so without this direct pin the hash-locked file lacks
# colorama and `pip install --require-hashes` fails on the windows-latest CI
# leg before tests even start. Pure-Python and tiny; harmless on Linux.
colorama>=0.4
# The build backend itself: workflows run `python -m build --no-isolation` so
# the one package that writes every byte of the published wheel is covered by
# the same hash pinning as everything else (an isolated build would download
# setuptools fresh and unpinned at publish time). >=77 per build-system.requires.
setuptools>=77
# Exercise the 'encoding' extra in CI: detect_encoding's charset_normalizer
# path is otherwise never executed by any automated test, so an upstream API
# change would first surface as a crash on users' machines.
charset-normalizer>=3.0
pytest>=8.0
ruff>=0.5
mypy>=1.10
